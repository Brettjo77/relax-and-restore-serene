---
import Icon from './Icon.astro';
import { testimonials } from '../data/site.js';
// Renders every testimonial as a card; grid adapts 3 → 2 → 1 across screen sizes.
---
<section class="section testimonial">
  <div class="section__inner">
    <header class="testimonial__head">
      <p class="eyebrow">Kind words</p>
      <h2 class="h2">What clients say</h2>
    </header>

    <ul class="testimonial__grid">
      {testimonials.map((t) => (
        <li>
          <figure class="testimonial__card">
            <div class="testimonial__stars" aria-label={`${t.rating} out of 5 stars`}>
              {Array.from({ length: t.rating }).map(() => (
                <Icon name="star" size={20} />
              ))}
            </div>
            <blockquote class="testimonial__quote">“{t.quote}”</blockquote>
            <figcaption class="testimonial__name">{t.name}</figcaption>
          </figure>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .testimonial { background: var(--blush); }
  .testimonial__head { text-align: center; max-width: 30ch; margin: 0 auto 32px; }

  .testimonial__grid {
    list-style: none;
    margin: 0; padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 26px;
    align-items: stretch;
  }
  /* Make each grid cell a flex container so the card fills the full row height. */
  .testimonial__grid > li { display: flex; }
  .testimonial__card {
    background: #fff;
    border-radius: var(--r-card);
    box-shadow: var(--shadow-card);
    text-align: center;
    padding: 38px 34px 34px;
    margin: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
  }
  .testimonial__stars {
    display: inline-flex;
    gap: 4px;
    color: var(--gold);
    margin-bottom: 20px;
    justify-content: center;
  }
  .testimonial__quote {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(18px, 1.6vw, 21px);
    line-height: 1.5;
    color: var(--brown-deep);
    margin: 0;
  }
  .testimonial__name {
    margin: 22px 0 0;
    padding-top: 4px;
    margin-top: auto;
    font-weight: 600;
    letter-spacing: .04em;
    color: var(--rose-text);
  }

  /* 3 → 2 across tablets, → 1 on phones (reuses the site's 860/640 breakpoints). */
  @media (max-width: 860px) {
    .testimonial__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      max-width: 40rem;
      margin-inline: auto;
    }
  }
  @media (max-width: 640px) {
    .testimonial__grid { grid-template-columns: 1fr; max-width: 30rem; }
    .testimonial__card { padding: 32px 26px 28px; }
  }
</style>
