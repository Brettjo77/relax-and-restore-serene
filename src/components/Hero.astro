---
// Direction 01 · Serene — centred hero with logo mark + script headline (spec §7.2, §8 Dir 01).
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
import spaHero from '../assets/img/spa-hero.png';
---
<section class="hero" id="hero">
  <Image
    src={spaHero}
    alt="Calming massage treatment setup with candles and towels"
    class="hero__img"
    widths={[768, 1280, 1920]}
    sizes="100vw"
    loading="eager"
    fetchpriority="high"
  />
  <div class="hero__overlay"></div>

  <div class="hero__content">
    <Image src={logo} alt="Lisa's Relax & Restore Massage logo" width={76} height={76} class="hero__logo" loading="eager" />
    <p class="hero__chip"><strong>10%</strong> off your first treatment for new clients</p>
    <h1 class="hero__title">
      <span class="script">Wellness for body,</span>
      <span class="serif">mind &amp; soul.</span>
    </h1>
    <p class="hero__sub">
      Professional Swedish massage in Lower Earley, Reading — from a calming home
      treatment room, or mobile across Wokingham, Bracknell, Sandhurst &amp; Crowthorne.
    </p>
    <div class="hero__cta">
      <a class="btn btn--sage" href="#contact">Book your treatment</a>
      <a class="btn btn--outline-light" href="#services">View treatments</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    margin-top: -76px;            /* slide under the transparent sticky nav */
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    isolation: isolate;
  }
  .hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }
  /* Cream gradient overlay for legibility (spec §7.2 — centred variant) */
  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      radial-gradient(120% 90% at 50% 45%, rgba(251,246,238,.86) 0%, rgba(251,246,238,.66) 42%, rgba(251,246,238,.30) 78%),
      linear-gradient(180deg, rgba(46,38,32,.25) 0%, rgba(46,38,32,.05) 30%, rgba(46,38,32,.30) 100%);
  }

  .hero__content {
    position: relative;
    z-index: 2;
    max-width: 760px;
    padding: 120px var(--gutter) 96px;
  }
  .hero__logo {
    width: 76px; height: 76px; border-radius: 50%;
    margin: 0 auto 22px;
    box-shadow: var(--shadow-card);
  }
  .hero__chip {
    display: inline-block;
    background: rgba(251, 246, 238, .9);
    border: 1px solid var(--line-2);
    color: var(--brown-deep);
    border-radius: var(--r-pill);
    padding: 8px 18px;
    font-size: 13px;
    margin: 0 0 26px;
  }
  .hero__chip strong { color: var(--sage-deep); }

  .hero__title {
    margin: 0;
    line-height: 1.04;
  }
  .hero__title .script {
    display: block;
    font-family: var(--font-script);
    color: var(--rose-text);
    font-size: clamp(40px, 7vw, 74px);
    line-height: 1;
  }
  .hero__title .serif {
    display: block;
    font-family: var(--font-display);
    color: var(--brown-deep);
    font-weight: 500;
    font-size: clamp(38px, 6vw, 64px);
    margin-top: 4px;
  }
  .hero__sub {
    margin: 22px auto 0;
    max-width: 38em;
    font-size: clamp(15px, 1.6vw, 17px);
    line-height: 1.7;
    color: var(--muted);
  }
  .hero__cta {
    margin-top: 32px;
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: center;
  }

  .btn--outline-light {
    background: rgba(251, 246, 238, .55);
    color: var(--brown-deep);
    border-color: var(--line-2);
  }
  .btn--outline-light:hover { border-color: var(--sage); color: var(--sage-deep); }

  @media (max-width: 640px) {
    .hero { min-height: 92vh; }
    .hero__content { padding: 104px var(--gutter) 72px; }
  }
</style>
