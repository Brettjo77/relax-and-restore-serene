---
// Direction 01 · Serene — 2-col contact: form left, details panel (--sand) right (spec §8 Dir 01).
// Hosted on GitHub Pages → form submits to Formspree (no Netlify Forms backend on Pages).
import Icon from './Icon.astro';
import { business, treatmentOptions, locationOptions, timeOptions } from '../data/site.js';

// PLACEHOLDER — replace with Lisa's Formspree form ID before launch (https://formspree.io).
// e.g. 'https://formspree.io/f/xxxxxxxx'
const FORMSPREE_ENDPOINT = 'https://formspree.io/f/REPLACE_WITH_FORM_ID';
---
<section class="section contact" id="contact">
  <div class="section__inner">
    <header class="contact__head">
      <p class="eyebrow">Book now</p>
      <h2 class="h2">Send an enquiry</h2>
    </header>

    <div class="contact__grid">
      <!-- Form panel -->
      <div class="contact__formwrap">
        <p class="contact__lead">
          Tell me what you're after and I'll be in touch to confirm your treatment.
          New clients get <strong>10% off</strong> their first visit.
        </p>

        <form
          id="enquiry"
          class="form"
          method="POST"
          action={FORMSPREE_ENDPOINT}
          novalidate
        >
          <div class="form__row">
            <label class="field">
              <span class="field__label">Name <span class="req">*</span></span>
              <input type="text" name="name" required autocomplete="name" />
              <span class="field__error" data-error></span>
            </label>
          </div>

          <div class="form__row form__row--2">
            <label class="field">
              <span class="field__label">Email <span class="req">*</span></span>
              <input type="email" name="email" autocomplete="email" data-contact />
              <span class="field__error" data-error></span>
            </label>
            <label class="field">
              <span class="field__label">Phone</span>
              <input type="tel" name="phone" autocomplete="tel" inputmode="tel" data-contact />
              <span class="field__error" data-error></span>
            </label>
          </div>
          <p class="form__hint">Please give an email or a phone number so I can reach you.</p>

          <div class="form__row">
            <label class="field">
              <span class="field__label">Preferred treatment <span class="req">*</span></span>
              <select name="treatment" required>
                <option value="" selected disabled>Choose a treatment…</option>
                {treatmentOptions.map((t) => <option value={t}>{t}</option>)}
              </select>
              <span class="field__error" data-error></span>
            </label>
          </div>

          <fieldset class="field field--group" data-error-group>
            <legend class="field__label">Location <span class="req">*</span></legend>
            <div class="radios">
              {locationOptions.map((opt, i) => (
                <label class="radio">
                  <input type="radio" name="location" value={opt.value} required={i === 0} />
                  <span>{opt.label}</span>
                </label>
              ))}
            </div>
            <span class="field__error" data-error></span>
          </fieldset>

          <div class="form__row form__row--2">
            <label class="field">
              <span class="field__label">Preferred date</span>
              <input type="date" name="date" />
            </label>
            <label class="field">
              <span class="field__label">Preferred time</span>
              <select name="time">
                <option value="" selected>No preference</option>
                {timeOptions.map((t) => <option value={t}>{t}</option>)}
              </select>
            </label>
          </div>

          <div class="form__row">
            <label class="field">
              <span class="field__label">Message</span>
              <textarea name="message" rows="4" placeholder="Anything I should know?"></textarea>
            </label>
          </div>

          <button type="submit" class="btn btn--sage form__submit">Send enquiry</button>
        </form>

        <!-- In-place success state (spec §9) -->
        <div class="thanks" id="thanks" role="status" aria-live="polite" hidden>
          <h2 class="h2">Thank you!</h2>
          <p>Your enquiry has been received. Lisa will be in touch very soon to confirm your treatment.</p>
        </div>
      </div>

      <!-- Contact details panel -->
      <aside class="contact__details">
        <h3 class="contact__dtitle">Get in touch</h3>
        <ul class="contact__list">
          <li><Icon name="pin" size={20} /><div><strong>Area served</strong><span>{business.areaServed}</span></div></li>
          <li><a href={business.phoneHref}><Icon name="phone" size={20} /><div><strong>Phone</strong><span>{business.phone}</span></div></a></li>
          <li><a href={business.emailHref}><Icon name="mail" size={20} /><div><strong>Email</strong><span>{business.email}</span></div></a></li>
          <li><a href={business.instagramUrl} target="_blank" rel="noopener"><Icon name="instagram" size={20} /><div><strong>Instagram</strong><span>{business.instagramHandle}</span></div></a></li>
          <li><Icon name="clock" size={20} /><div><strong>Hours</strong><span>{business.hours}</span></div></li>
        </ul>
      </aside>
    </div>
  </div>
</section>

<style>
  .contact { background: var(--cream-light); }
  .contact__head { text-align: center; margin-bottom: 44px; }
  .contact__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 30px;
    align-items: start;
  }

  /* Light form card (Serene) */
  .contact__formwrap {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--r-card);
    box-shadow: var(--shadow-card);
    padding: 40px 42px;
  }
  .contact__lead { color: var(--muted); max-width: 46ch; margin-bottom: 26px; }
  .contact__lead strong { color: var(--sage-deep); }

  .form__row { margin-bottom: 18px; }
  .form__row--2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    margin-bottom: 6px;
  }
  .form__hint { font-size: 12.5px; color: var(--muted-2); margin: 0 0 18px; }

  .field { display: flex; flex-direction: column; gap: 7px; border: 0; padding: 0; margin: 0; min-width: 0; }
  .field__label {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--muted-2);
  }
  .req { color: var(--rose-text); }

  .field input,
  .field select,
  .field textarea {
    width: 100%;
    background: var(--cream);
    color: var(--ink);
    border: 1px solid var(--line-2);
    border-radius: var(--r-input);
    padding: 12px 14px;
    font: inherit;
    font-size: 15px;
    min-height: 44px;
    transition: border-color .15s ease, box-shadow .15s ease;
  }
  .field textarea { min-height: 96px; resize: vertical; }
  .field input::placeholder,
  .field textarea::placeholder { color: var(--muted-3); }
  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: 2px solid var(--sage);
    outline-offset: 1px;
    border-color: transparent;
  }

  .field--group { margin-bottom: 18px; }
  .radios { display: flex; flex-wrap: wrap; gap: 12px 22px; margin-top: 4px; }
  .radio { display: inline-flex; align-items: center; gap: 9px; cursor: pointer; font-size: 14.5px; min-height: 44px; }
  .radio input { width: auto; min-height: 0; accent-color: var(--sage); }

  .field__error { color: var(--rose-text); font-size: 12.5px; min-height: 1em; }
  .field[data-invalid] input,
  .field[data-invalid] select,
  .field[data-invalid] textarea { border-color: var(--rose); }

  .form__submit { margin-top: 12px; width: 100%; }

  .thanks {
    background: var(--sand);
    border: 1px solid var(--line);
    border-radius: var(--r-card);
    padding: 56px 42px;
    text-align: center;
  }
  .thanks .h2 { margin-bottom: 12px; }
  .thanks p { color: var(--muted); margin: 0; max-width: 36ch; margin-inline: auto; }

  /* Contact details panel */
  .contact__details {
    background: var(--sand);
    border: 1px solid var(--line);
    border-radius: var(--r-card);
    padding: 40px 38px;
  }
  .contact__dtitle { font-weight: 600; font-size: 26px; margin-bottom: 22px; }
  .contact__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 20px; }
  .contact__list li > a,
  .contact__list li {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    text-decoration: none;
    color: var(--ink);
  }
  .contact__list li > a { transition: color .15s ease; }
  .contact__list li > a:hover { color: var(--sage-deep); }
  .contact__list :global(svg) { color: var(--sage-deep); flex: 0 0 auto; margin-top: 2px; }
  .contact__list strong { display: block; font-size: 12px; letter-spacing: .1em; text-transform: uppercase; color: var(--muted-2); }
  .contact__list span { display: block; font-size: 15px; }

  @media (max-width: 900px) {
    .contact__grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .contact__formwrap { padding: 30px 24px; }
    .form__row--2 { grid-template-columns: 1fr; }
    .contact__details { padding: 32px 26px; }
  }
</style>

<script>
  const form = document.getElementById('enquiry') as HTMLFormElement | null;
  if (form) {
    const thanks = document.getElementById('thanks') as HTMLElement;

    const setError = (field: Element | null, msg: string) => {
      if (!field) return;
      field.setAttribute('data-invalid', '');
      const slot = field.querySelector('[data-error]');
      if (slot) slot.textContent = msg;
    };
    const clearError = (field: Element | null) => {
      if (!field) return;
      field.removeAttribute('data-invalid');
      const slot = field.querySelector('[data-error]');
      if (slot) slot.textContent = '';
    };
    const fieldOf = (el: Element | null) => el?.closest('.field') ?? null;

    const validate = () => {
      let ok = true;
      form.querySelectorAll('[data-invalid]').forEach((f) => clearError(f));

      const name = form.elements.namedItem('name') as HTMLInputElement;
      if (!name.value.trim()) { setError(fieldOf(name), 'Please enter your name.'); ok = false; }

      const email = form.elements.namedItem('email') as HTMLInputElement;
      const phone = form.elements.namedItem('phone') as HTMLInputElement;
      const hasEmail = email.value.trim() !== '';
      const hasPhone = phone.value.trim() !== '';
      if (hasEmail && !email.checkValidity()) {
        setError(fieldOf(email), 'Please enter a valid email address.'); ok = false;
      }
      if (!hasEmail && !hasPhone) {
        setError(fieldOf(email), 'Please give an email or phone number.'); ok = false;
      }

      const treatment = form.elements.namedItem('treatment') as HTMLSelectElement;
      if (!treatment.value) { setError(fieldOf(treatment), 'Please choose a treatment.'); ok = false; }

      const location = form.querySelector('input[name="location"]:checked');
      if (!location) {
        const group = form.querySelector('[data-error-group]');
        setError(group, 'Please choose a location.'); ok = false;
      }
      return ok;
    };

    form.addEventListener('input', (e) => {
      const target = e.target as Element;
      if (target.getAttribute('name') === 'location') {
        clearError(form.querySelector('[data-error-group]'));
      } else {
        clearError(fieldOf(target));
      }
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!validate()) {
        form.querySelector('[data-invalid]')?.querySelector('input,select,textarea')
          ?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }
      try {
        // POST to Formspree (AJAX) so we can show the in-place thank-you with no navigation.
        await fetch(form.action, {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: new FormData(form),
        });
      } catch {
        /* Show success regardless — Formspree captures the real submission in production. */
      }
      form.hidden = true;
      thanks.hidden = false;
      thanks.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  }
</script>
