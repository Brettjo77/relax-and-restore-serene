---
// Direction 01 · Serene — compact, equal treatment cards: round thumbnail (photo or icon) + text.
import { Image } from 'astro:assets';
import Icon from './Icon.astro';
import { services, business } from '../data/site.js';
import { images, imageAlt } from '../data/images.js';
---
<section class="section services" id="services">
  <div class="section__inner">
    <header class="services__head">
      <p class="eyebrow">Treatments</p>
      <h2 class="h2">A gentle touch that heals body, mind &amp; soul</h2>
    </header>

    <ul class="cards">
      {services.map((s) => (
        <li class="card">
          <span class="card__thumb">
            {s.image ? (
              <Image
                src={images[s.image]}
                alt={imageAlt[s.image]}
                class="card__img"
                widths={[120, 240]}
                sizes="72px"
                loading="lazy"
              />
            ) : (
              <Icon name={s.icon} size={30} />
            )}
          </span>
          <div class="card__body">
            <h3 class="card__name">{s.name}</h3>
            <p class="card__dur">{s.durations}</p>
            <p class="card__desc">{s.description}</p>
            <a class="btn btn--sage card__book" href="#contact">Book</a>
          </div>
        </li>
      ))}
    </ul>

    <p class="services__foot">{business.pricingNote} · {business.offer}</p>
  </div>
</section>

<style>
  .services { background: var(--sand); }
  .services__head { text-align: center; max-width: 30ch; margin: 0 auto 34px; }

  .cards {
    list-style: none;
    margin: 0; padding: 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 24px;
    align-items: stretch;
  }
  .card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--r-card);
    box-shadow: var(--shadow-card);
    padding: 28px 24px 26px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
  }
  /* Round thumbnail: photo or icon, same size for every card */
  .card__thumb {
    width: 72px; height: 72px;
    border-radius: 50%;
    overflow: hidden;
    flex: 0 0 auto;
    display: grid; place-items: center;
    background: var(--sand);
    color: var(--sage-deep);
    margin-bottom: 16px;
    transition: transform .25s ease, background-color .25s ease, color .25s ease;
  }
  .card__img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* Hover: lift the card, lift & accent the thumbnail */
  @media (prefers-reduced-motion: no-preference) {
    .card:hover { transform: translateY(-6px); }
    .card:hover .card__thumb { transform: scale(1.06); }
  }
  .card:hover {
    box-shadow: 0 14px 30px rgba(67, 48, 31, .14);
    border-color: var(--sage);
  }
  .card:hover .card__thumb { background: var(--sage); color: #fff; }
  .card:focus-within { border-color: var(--sage); }

  .card__body { display: flex; flex-direction: column; align-items: center; flex: 1; }
  .card__name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 17.5px;
    line-height: 1.35;
    color: var(--brown-deep);
    margin: 0;
    min-height: 2.7em;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .card__dur {
    margin: 7px 0 0;
    font-size: 11px;
    letter-spacing: .13em;
    text-transform: uppercase;
    color: var(--muted-2);
  }
  .card__desc { margin: 11px 0 0; font-size: 14px; color: var(--muted); line-height: 1.55; }
  .card__book { margin-top: auto; padding-top: 18px; }

  .services__foot { margin: 30px 0 0; text-align: center; font-size: 13px; color: var(--muted-2); }

  /* 4 → 2 (tablet) → 1 (phone), reusing the site's 860/640 breakpoints */
  @media (max-width: 860px) {
    .cards { grid-template-columns: repeat(2, minmax(0, 1fr)); max-width: 34rem; margin-inline: auto; }
  }
  @media (max-width: 480px) {
    .cards { grid-template-columns: 1fr; max-width: 22rem; }
  }
</style>
