---
// Direction 01 · Serene — compact, equal treatment cards: round thumbnail (photo or icon) + text.
import { Image } from 'astro:assets';
import Icon from './Icon.astro';
import { services, business } from '../data/site.js';
import { images, imageAlt } from '../data/images.js';
---
<section class="section services" id="services">
  <div class="section__inner">
    <header class="services__head">
      <p class="eyebrow">Treatments</p>
      <h2 class="h2">A gentle touch that heals body, mind &amp; soul</h2>
    </header>

    <ul class="cards">
      {services.map((s) => (
        <li class="card">
          <span class="card__thumb">
            {s.image ? (
              <Image
                src={images[s.image]}
                alt={imageAlt[s.image]}
                class="card__img"
                widths={[160, 320]}
                sizes="88px"
                loading="lazy"
              />
            ) : (
              <Icon name={s.icon} size={36} />
            )}
          </span>
          <div class="card__body">
            <div class="card__top">
              <h3 class="card__name">{s.name}</h3>
              <span class="card__dur">{s.durations}</span>
            </div>
            <p class="card__desc">{s.description}</p>
          </div>
          <a class="btn btn--sage card__book" href="#contact">Book</a>
        </li>
      ))}
    </ul>

    <p class="services__foot">{business.pricingNote} · {business.offer}</p>
  </div>
</section>

<style>
  .services { background: var(--sand); }
  .services__head { text-align: center; max-width: 30ch; margin: 0 auto 34px; }

  /* Horizontal rows: thumbnail left, text middle, Book right */
  .cards {
    list-style: none;
    margin: 0 auto; padding: 0;
    max-width: 760px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--r-card);
    box-shadow: var(--shadow-card);
    padding: 22px 26px;
    display: flex;
    align-items: center;
    gap: 24px;
    transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
  }
  /* Round thumbnail: photo or icon, same size for every card */
  .card__thumb {
    width: 88px; height: 88px;
    border-radius: 50%;
    overflow: hidden;
    flex: 0 0 auto;
    display: grid; place-items: center;
    background: var(--sand);
    color: var(--sage-deep);
    transition: transform .25s ease, background-color .25s ease, color .25s ease;
  }
  .card__img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .card__body { flex: 1; min-width: 0; }
  .card__top { display: flex; align-items: baseline; flex-wrap: wrap; gap: 6px 14px; }
  .card__name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 21px;
    line-height: 1.2;
    color: var(--brown-deep);
    margin: 0;
  }
  .card__dur {
    font-size: 11px;
    letter-spacing: .13em;
    text-transform: uppercase;
    color: var(--muted-2);
  }
  .card__desc { margin: 8px 0 0; font-size: 14.5px; color: var(--muted); line-height: 1.55; }
  .card__book { flex: 0 0 auto; }

  /* Hover: lift the row, accent the thumbnail */
  @media (prefers-reduced-motion: no-preference) {
    .card:hover { transform: translateY(-4px); }
    .card:hover .card__thumb { transform: scale(1.06); }
  }
  .card:hover {
    box-shadow: 0 14px 30px rgba(67, 48, 31, .14);
    border-color: var(--sage);
  }
  .card:hover .card__thumb { background: var(--sage); color: #fff; }
  .card:focus-within { border-color: var(--sage); }

  .services__foot { margin: 30px 0 0; text-align: center; font-size: 13px; color: var(--muted-2); }

  /* Stack the row contents on small phones */
  @media (max-width: 560px) {
    .card { flex-direction: column; text-align: center; gap: 14px; padding: 26px 22px; }
    .card__top { flex-direction: column; align-items: center; gap: 4px; }
    .card__book { width: 100%; max-width: 220px; }
  }
</style>
