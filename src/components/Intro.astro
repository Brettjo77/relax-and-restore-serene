---
// Quick "what I do" summary right after the hero — the actual treatments, before the detail.
import Icon from './Icon.astro';
import { services } from '../data/site.js';

// Icon + one-line summary per treatment, keyed to the service name so it stays in sync
// with site.js. Falls back to the lotus icon / the service's own description if unmatched.
const meta = {
  'Swedish Full Body Massage': { icon: 'lotus', body: 'Relaxing full-body massage for deep relaxation and stress relief.' },
  'Back, Neck & Shoulder Massage': { icon: 'muscle', body: 'Targeted relief for tension where you carry stress the most.' },
  'Pedicures': { icon: 'flex', body: 'A restorative pedicure to leave your feet feeling cared for.' },
  'Lymphatic Drainage': { icon: 'circulation', body: 'Gentle, rhythmic treatment to reduce puffiness and support wellbeing.' },
};

const pillars = services.map((s) => ({
  icon: meta[s.name]?.icon ?? 'lotus',
  title: s.name,
  body: meta[s.name]?.body ?? s.description,
}));
---
<section class="section intro">
  <div class="section__inner">
    <p class="eyebrow intro__eyebrow">What I do</p>
    <p class="intro__lead">
      Professional treatments in Lower Earley — mobile to your home, or in a peaceful
      treatment room. Here to help you relax, restore and feel like yourself again.
    </p>

    <ul class="intro__pillars">
      {pillars.map((p) => (
        <li class="intro__pillar">
          <span class="intro__icon"><Icon name={p.icon} size={24} /></span>
          <h3 class="intro__ptitle">{p.title}</h3>
          <p class="intro__pbody">{p.body}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .intro { background: var(--cream); }
  .intro__eyebrow { text-align: center; }
  .intro__lead {
    max-width: 46ch;
    margin: 10px auto 0;
    text-align: center;
    font-family: var(--font-display);
    font-size: clamp(19px, 2vw, 24px);
    line-height: 1.5;
    color: var(--brown-deep);
  }

  .intro__pillars {
    list-style: none;
    margin: 38px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 26px;
  }
  .intro__pillar { text-align: center; }
  .intro__icon {
    display: inline-grid;
    place-items: center;
    width: 56px; height: 56px;
    border-radius: 50%;
    background: var(--sand);
    color: var(--sage-deep);
    margin-bottom: 14px;
  }
  .intro__ptitle {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 19px;
    color: var(--brown-deep);
    margin: 0 0 6px;
  }
  .intro__pbody { color: var(--muted); line-height: 1.6; margin: 0; max-width: 30ch; margin-inline: auto; }

  /* 4 → 2 across tablets, → 1 on phones (reuses the site's 860/640 breakpoints). */
  @media (max-width: 860px) {
    .intro__pillars { grid-template-columns: repeat(2, minmax(0, 1fr)); max-width: 38rem; margin-inline: auto; }
  }
  @media (max-width: 640px) {
    .intro__pillars { grid-template-columns: 1fr; gap: 22px; max-width: 24rem; }
  }
</style>
