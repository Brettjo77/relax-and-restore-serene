---
// Simple line/stroke SVG icons (1.5–2px stroke, spec §7.5).
// Usage: <Icon name="calm" /> — inherits currentColor.
const { name, size = 26, class: className = '' } = Astro.props;

const paths = {
  // Benefits
  muscle: '<path d="M6 12c2-3 4-3 6 0s4 3 6 0"/><path d="M4 8c1.5-2 3-2 4 0M16 16c1-1.5 2.5-1.5 4 0"/>',
  circulation: '<path d="M12 21s-7-4.5-7-10a4 4 0 0 1 7-2.6A4 4 0 0 1 19 11c0 5.5-7 10-7 10Z"/>',
  calm: '<path d="M12 3a6 6 0 0 0 0 12 6 6 0 0 1 0-12Z"/><path d="M12 15v6M8 21h8"/>',
  sleep: '<path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"/>',
  flex: '<circle cx="12" cy="5" r="2"/><path d="M12 7v6m0 0-4 6m4-6 4 6M7 10l5 1 5-1"/>',
  heal: '<path d="M12 21s-7-4.5-7-10a4 4 0 0 1 7-2.6A4 4 0 0 1 19 11c0 5.5-7 10-7 10Z"/><path d="M12 8v6M9 11h6"/>',
  // Ways
  home: '<path d="M4 11 12 4l8 7"/><path d="M6 10v9h12v-9"/><path d="M10 19v-5h4v5"/>',
  lotus: '<path d="M12 20c-4 0-7-2.5-7-5 2 0 3.5 1 4.5 2"/><path d="M12 20c4 0 7-2.5 7-5-2 0-3.5 1-4.5 2"/><path d="M12 20c-2.5 0-4-2-4-4.5 1.5.3 3 1.5 4 3 1-1.5 2.5-2.7 4-3 0 2.5-1.5 4.5-4 4.5Z"/><path d="M12 20c0-3 0-6 0-9 1.5 1.5 2.5 4 0 9-2.5-5-1.5-7.5 0-9"/>',
  // Footer / contact
  phone: '<path d="M5 4h3l2 5-2.5 1.5a11 11 0 0 0 5 5L19 18l1 3v0a2 2 0 0 1-2 1.5A15 15 0 0 1 3.5 6 2 2 0 0 1 5 4Z"/>',
  mail: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/>',
  instagram: '<rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1"/>',
  pin: '<path d="M12 21s-7-5.5-7-11a7 7 0 0 1 14 0c0 5.5-7 11-7 11Z"/><circle cx="12" cy="10" r="2.5"/>',
  clock: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
  star: '<path d="m12 3 2.6 5.6 6 .7-4.4 4.1 1.2 6L12 16.6 6.6 19.4l1.2-6L3.4 9.3l6-.7Z"/>',
  // Socials — filled brand glyphs (inherit currentColor):
  facebook: '<path d="M14 9V7.2c0-.7.3-1.2 1.3-1.2H16.5V3.1A17 17 0 0 0 14.5 3C12.3 3 11 4.3 11 6.7V9H8.5v3H11v9h3v-9h2.4l.4-3H14Z"/>',
  tiktok: '<path d="M16.5 3c.4 2 1.6 3.5 3.5 3.9v3a6.6 6.6 0 0 1-3.5-1v5.7a5.6 5.6 0 1 1-5.6-5.6c.3 0 .6 0 .9.1v3.1a2.6 2.6 0 1 0 1.8 2.5V3h2.9Z"/>',
};

// Filled glyphs (brand marks + star) vs. line icons (everything else).
const filled = ['star', 'facebook', 'tiktok'].includes(name);
const inner = paths[name] ?? '';
---
<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={filled ? 'currentColor' : 'none'}
  stroke={filled ? 'none' : 'currentColor'}
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={inner}
/>
