# Copy this file to `.env` and fill in the real value. `.env` is gitignored.
#
# Formspree form ID for the enquiry form (https://formspree.io).
# 1. Sign up / log in at formspree.io with lisarelax@outlook.com.
# 2. Create a new form (name it e.g. "Relax & Restore enquiry").
# 3. Its endpoint looks like https://formspree.io/f/abcdwxyz — copy just the
#    last part (the 8-character ID, here `abcdwxyz`) into the line below.
# 4. In the form's settings, make sure the notification email is lisarelax@outlook.com.
#
# Until this is set, the contact form shows the "email/call me instead" fallback
# rather than silently dropping enquiries.
PUBLIC_FORMSPREE_ID=REPLACE_WITH_FORM_ID
